# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# A shared password used to register/login OAuth users in the GraphQL API
OAUTH_USER_PASSWORD=change-this-to-a-long-random-string

# Session secret
SESSION_SECRET=change-this-to-a-long-random-string

# URLs
CLIENT_URL=http://localhost:5173
SERVER_PORT=3001
VITE_GRAPHQL_URL=https://netflix-graphql-api-production.up.railway.app/graphql
