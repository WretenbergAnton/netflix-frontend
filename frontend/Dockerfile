FROM node:20-alpine
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG VITE_AUTH_SERVER_URL
ARG VITE_GRAPHQL_URL
ARG VITE_TMDB_TOKEN
ENV VITE_AUTH_SERVER_URL=$VITE_AUTH_SERVER_URL
ENV VITE_GRAPHQL_URL=$VITE_GRAPHQL_URL
ENV VITE_TMDB_TOKEN=$VITE_TMDB_TOKEN

RUN npm run build

EXPOSE 8080
CMD ["node", "server/index.js"]
